{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ekstre",
  "version": "0.2.0",
  "identifier": "com.denizozogul.ekstre",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Ekstre",
        "label": "main",
        "width": 420,
        "height": 720,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Finance",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": ["resources/pdfium/libpdfium.dylib"]
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxMzhBMUE2RDkwOEZBMjQKUldRaytnalpwcUU0Z1MrcWlmTXVZM3pzeVVVNXpnY1JjbVJZRVBPaG9VZk1LcCtTN0djclVXRk0K",
      "endpoints": [
        "https://github.com/atomdeniz/ekstre-desktop/releases/latest/download/latest.json"
      ]
    }
  }
}
